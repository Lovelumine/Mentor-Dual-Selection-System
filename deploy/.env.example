# Copy this file to deploy/.env before deployment.

DEPLOY_HOST=
DEPLOY_PORT=22
DEPLOY_USER=
DEPLOY_APP_DIR=

SERVER_PORT=50000

SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/teacherselectionsystem?useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=replace-me
SPRING_DATASOURCE_PASSWORD=replace-me

SPRING_MAIL_HOST=smtp.exmail.qq.com
SPRING_MAIL_PORT=465
SPRING_MAIL_USERNAME=replace-me
SPRING_MAIL_PASSWORD=replace-me
APP_MAIL_FROM=no-reply@example.com

MINIO_URL=http://127.0.0.1:9000
